DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:5432/postgres?sslmode=require"
JWT_ACCESS_SECRET="replace-with-a-32-plus-character-access-secret"
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET="replace-with-a-32-plus-character-refresh-secret"
JWT_REFRESH_TTL=7d
SEED_ADMIN_PASSWORD="replace-with-a-secure-admin-password"
SEED_LIBRARIAN_PASSWORD="replace-with-a-secure-librarian-password"
SEED_LEADER_PASSWORD="replace-with-a-secure-leader-password"
PORT=3000
NODE_ENV=development
SKIP_DB_CONNECTION=false
